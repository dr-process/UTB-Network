<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Data Communication & Networking 1 — Quiz</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0f1e;
    --surface: #111827;
    --surface2: #1a2235;
    --border: rgba(255,255,255,0.07);
    --border-hover: rgba(45,212,191,0.4);
    --accent: #2dd4bf;
    --accent-dim: rgba(45,212,191,0.10);
    --accent-glow: rgba(45,212,191,0.22);
    --green: #68d391;
    --green-dim: rgba(104,211,145,0.12);
    --red: #fc8181;
    --red-dim: rgba(252,129,129,0.12);
    --amber: #f6ad55;
    --amber-dim: rgba(246,173,85,0.12);
    --text: #e2e8f0;
    --muted: #718096;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Space Grotesk', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    line-height: 1.6;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(45,212,191,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(45,212,191,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .wrap { max-width: 800px; margin: 0 auto; padding: 2rem 1.25rem 5rem; position: relative; z-index: 1; }

  /* ── Hero ── */
  .hero {
    text-align: center;
    padding: 3rem 2rem 2.5rem;
    background: linear-gradient(135deg, rgba(45,212,191,0.08) 0%, rgba(17,24,39,0) 60%);
    border: 1px solid var(--border);
    border-radius: 20px;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -60px; left: 50%;
    transform: translateX(-50%);
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(45,212,191,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    background: var(--accent-dim);
    border: 1px solid rgba(45,212,191,0.2);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 1rem;
  }
  .hero h1 {
    font-size: clamp(22px, 4vw, 30px);
    font-weight: 700;
    color: #fff;
    margin-bottom: 6px;
    letter-spacing: -0.5px;
  }
  .hero p { font-size: 15px; color: var(--muted); }

  /* ── Progress ── */
  .progress-wrap { margin-bottom: 2rem; }
  .progress-meta {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--muted);
    font-family: var(--mono);
    margin-bottom: 8px;
  }
  .progress-track { height: 4px; background: var(--surface2); border-radius: 4px; overflow: hidden; }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), #5eead4);
    border-radius: 4px;
    transition: width 0.4s cubic-bezier(.4,0,.2,1);
    box-shadow: 0 0 12px rgba(45,212,191,0.35);
  }

  /* ── Question Card ── */
  .q-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.75rem;
    margin-bottom: 1rem;
    transition: border-color 0.2s;
  }
  .q-card:hover { border-color: rgba(255,255,255,0.10); }
  .q-card.answered { border-color: rgba(45,212,191,0.2); }

  .q-header { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; }
  .q-num {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(45,212,191,0.2);
    padding: 3px 10px;
    border-radius: 20px;
    white-space: nowrap;
  }
  .multi-badge {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--amber);
    background: var(--amber-dim);
    border: 1px solid rgba(246,173,85,0.2);
    padding: 3px 10px;
    border-radius: 20px;
  }
  .q-text {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  /* ── Options ── */
  .options { display: flex; flex-direction: column; gap: 8px; }
  .option {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 16px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.15s ease;
    font-size: 14px;
    color: var(--text);
    user-select: none;
  }
  .option:hover { border-color: var(--border-hover); background: rgba(45,212,191,0.05); color: #fff; }
  .option.selected { border-color: var(--accent); background: var(--accent-dim); color: #fff; }
  .option.correct  { border-color: var(--green); background: var(--green-dim); color: var(--green); }
  .option.wrong    { border-color: var(--red);   background: var(--red-dim);   color: var(--red);   }
  .option.show-correct { border-color: var(--green); background: var(--green-dim); color: var(--green); }

  .opt-marker {
    width: 26px; height: 26px;
    border-radius: 50%;
    border: 1.5px solid currentColor;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--mono);
    font-size: 11px; font-weight: 600;
    flex-shrink: 0;
    opacity: 0.7;
  }
  .option.selected .opt-marker,
  .option.correct  .opt-marker,
  .option.wrong    .opt-marker,
  .option.show-correct .opt-marker { opacity: 1; }

  /* ── Submit Bar ── */
  .submit-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    margin-top: 1.5rem;
  }
  .submit-info { font-size: 13px; color: var(--muted); font-family: var(--mono); }

  .btn {
    font-family: var(--sans);
    font-size: 14px; font-weight: 600;
    padding: 10px 28px;
    border-radius: 10px; border: none;
    cursor: pointer;
    transition: all 0.15s ease;
    letter-spacing: 0.3px;
  }
  .btn-primary { background: var(--accent); color: #0a0f1e; }
  .btn-primary:hover { background: #5eead4; transform: translateY(-1px); box-shadow: 0 4px 20px rgba(45,212,191,0.28); }
  .btn-primary:disabled { opacity: 0.35; cursor: not-allowed; transform: none; box-shadow: none; }
  .btn-ghost { background: transparent; color: var(--accent); border: 1px solid rgba(45,212,191,0.3); }
  .btn-ghost:hover { background: var(--accent-dim); }

  /* ── Result Screen ── */
  #result-screen { display: none; }

  .result-hero {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    text-align: center;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .result-hero::before {
    content: '';
    position: absolute;
    top: -80px; left: 50%;
    transform: translateX(-50%);
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(45,212,191,0.06) 0%, transparent 65%);
    pointer-events: none;
  }

  .score-circle { width: 140px; height: 140px; margin: 0 auto 1.5rem; position: relative; }
  .score-circle svg { width: 100%; height: 100%; transform: rotate(-90deg); }
  .score-circle-text {
    position: absolute; inset: 0;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
  }
  .score-pct { font-size: 30px; font-weight: 700; color: #fff; font-family: var(--mono); }
  .score-lbl { font-size: 11px; color: var(--muted); font-family: var(--mono); letter-spacing: 1px; }

  .grade-badge {
    display: inline-block;
    font-size: 15px; font-weight: 600;
    padding: 6px 20px;
    border-radius: 20px;
    margin-bottom: 1rem;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 1.5rem;
  }
  .stat-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem;
    text-align: center;
  }
  .stat-num { font-size: 28px; font-weight: 700; font-family: var(--mono); }
  .stat-lbl { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .c-green { color: var(--green); }
  .c-red   { color: var(--red); }
  .c-blue  { color: var(--accent); }

  .review-heading {
    font-size: 13px;
    font-family: var(--mono);
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 2rem 0 1rem;
    padding-bottom: .75rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .review-heading::before {
    content: ''; display: block;
    width: 3px; height: 14px;
    background: var(--accent);
    border-radius: 2px;
  }

  .review-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    margin-bottom: .75rem;
  }
  .review-item.ri-correct { border-color: rgba(104,211,145,0.25); }
  .review-item.ri-wrong   { border-color: rgba(252,129,129,0.25); }

  .ri-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: .75rem;
  }
  .ri-q { font-size: 14px; font-weight: 500; color: var(--text); line-height: 1.55; margin-bottom: .75rem; }
  .ri-answers { display: flex; flex-direction: column; gap: 6px; }
  .ri-answer {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 13px;
    padding: 7px 12px;
    border-radius: 8px;
    line-height: 1.5;
  }
  .ri-answer.your    { background: var(--red-dim);   color: var(--red); }
  .ri-answer.correct { background: var(--green-dim); color: var(--green); }

  .pill {
    display: inline-flex; align-items: center; gap: 4px;
    font-family: var(--mono);
    font-size: 11px; font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
  }
  .pill-green { background: var(--green-dim); color: var(--green); border: 1px solid rgba(104,211,145,0.25); }
  .pill-red   { background: var(--red-dim);   color: var(--red);   border: 1px solid rgba(252,129,129,0.25); }
  .pill-num   { background: var(--surface2);  color: var(--muted); border: 1px solid var(--border); }

  .divider { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

  @media (max-width: 520px) {
    .stats-row { grid-template-columns: 1fr 1fr; }
    .hero { padding: 2rem 1.25rem; }
  }
</style>
</head>
<body>
<div class="wrap">

  <!-- HERO -->
  <div class="hero">
    <div class="hero-tag">Quiz — Chapter Review</div>
    <h1>Data Communication &amp; Networking 1</h1>
    <p>25 Questions &nbsp;·&nbsp; Multiple Choice &nbsp;·&nbsp; Instant Feedback</p>
  </div>

  <!-- QUIZ SCREEN -->
  <div id="quiz-screen">
    <div class="progress-wrap">
      <div class="progress-meta">
        <span id="prog-text">0 / 25 answered</span>
        <span id="prog-pct">0%</span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" id="prog-fill" style="width:0%"></div>
      </div>
    </div>

    <div id="questions-list"></div>

    <div class="submit-bar">
      <span class="submit-info" id="submit-info">Answer all questions to submit</span>
      <button class="btn btn-primary" id="submit-btn" disabled onclick="submitQuiz()">Submit Quiz →</button>
    </div>
  </div>

  <!-- RESULT SCREEN -->
  <div id="result-screen">
    <div class="result-hero">
      <div class="score-circle">
        <svg viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="52" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="10"/>
          <circle cx="60" cy="60" r="52" fill="none" stroke="var(--accent)" stroke-width="10"
            stroke-linecap="round" stroke-dasharray="0 327" id="score-arc"
            style="transition:stroke-dasharray 1s cubic-bezier(.4,0,.2,1)"/>
        </svg>
        <div class="score-circle-text">
          <div class="score-pct" id="score-pct-text">0%</div>
          <div class="score-lbl">SCORE</div>
        </div>
      </div>
      <div class="grade-badge" id="grade-badge"></div>
      <div class="stats-row">
        <div class="stat-card"><div class="stat-num c-green" id="r-correct">0</div><div class="stat-lbl">Correct</div></div>
        <div class="stat-card"><div class="stat-num c-red"   id="r-wrong">0</div><div class="stat-lbl">Wrong</div></div>
        <div class="stat-card"><div class="stat-num c-blue">25</div><div class="stat-lbl">Total</div></div>
      </div>
    </div>

    <div class="review-heading">Answer Review</div>
    <div id="review-list"></div>

    <hr class="divider">
    <div style="text-align:center">
      <button class="btn btn-ghost" onclick="resetQuiz()">↩ Retake Quiz</button>
    </div>
  </div>

</div>

<script>
const Q = [
  {
    n:1, multi:false,
    t:"A network administrator needs to keep the user ID, password, and session contents private when establishing remote CLI connectivity with a switch to manage it. Which access method should be chosen?",
    opts:["Telnet","Console","AUX","SSH"],
    ans:[3]
  },
  {
    n:2, multi:false,
    t:"Which procedure is used to access a Cisco 2960 switch when performing an initial configuration in a secure environment?",
    opts:[
      "Use Telnet to remotely access the switch through the network.",
      "Use the console port to locally access the switch from a serial or USB interface of the PC.",
      "Use Secure Shell to remotely access the switch through the network.",
      "Use the AUX port to locally access the switch from a serial or USB interface of the PC."
    ],
    ans:[1]
  },
  {
    n:3, multi:false,
    t:"Which command or key combination allows a user to return to the previous level in the command hierarchy?",
    opts:["end","exit","Ctrl-Z","Ctrl-C"],
    ans:[1]
  },
  {
    n:4, multi:false,
    t:"A router has a valid operating system and a configuration file stored in NVRAM. The configuration file contains an enable secret password but no console password. When the router boots up, which mode will display?",
    opts:["Global configuration mode","Setup mode","Privileged EXEC mode","User EXEC mode"],
    ans:[3]
  },
  {
    n:5, multi:true,
    t:"Which two functions are provided to users by the context-sensitive help feature of the Cisco IOS CLI? (Choose two.)",
    opts:[
      "Providing an error message when a wrong command is submitted",
      "Displaying a list of all available commands within the current mode",
      "Allowing the user to complete the remainder of an abbreviated command with the TAB key",
      "Determining which option, keyword, or argument is available for the entered command",
      "Selecting the best command to accomplish a task"
    ],
    ans:[1,3]
  },
  {
    n:6, multi:false,
    t:"Which information does the show startup-config command display?",
    opts:[
      "The IOS image copied into RAM",
      "The bootstrap program in the ROM",
      "The contents of the current running configuration file in the RAM",
      "The contents of the saved configuration file in the NVRAM"
    ],
    ans:[3]
  },
  {
    n:7, multi:true,
    t:"Which two host names follow the guidelines for naming conventions on Cisco IOS devices? (Choose two.)",
    opts:["Branch2!","RM-3-Switch-2A4","Floor(15)","HO Floor 17","SwBranch799"],
    ans:[1,4]
  },
  {
    n:8, multi:false,
    t:"A router with a valid operating system contains a configuration file stored in NVRAM. The configuration file has an enable secret password but no console password. When the router boots up, which mode will display?",
    opts:["Privileged EXEC mode","Setup mode","User EXEC mode","Global configuration mode"],
    ans:[2]
  },
  {
    n:9, multi:true,
    t:"What are two characteristics of RAM on a Cisco device? (Choose two.)",
    opts:[
      "RAM provides nonvolatile storage.",
      "The configuration that is actively running on the device is stored in RAM.",
      "The contents of RAM are lost during a power cycle.",
      "RAM is a component in Cisco switches but not in Cisco routers.",
      "RAM is able to store multiple versions of IOS and configuration files."
    ],
    ans:[1,2]
  },
  {
    n:10, multi:false,
    t:"What command can be used on a Windows PC to see the IP configuration of that computer?",
    opts:["ping","ipconfig","show interfaces","show ip interface brief"],
    ans:[1]
  },
  {
    n:11, multi:false,
    t:"A technician is adding a new PC to a LAN. After unpacking the components and making all the connections, the technician starts the PC. After the OS loads, the technician opens a browser, and verifies that the PC can reach the Internet. Why was the PC able to connect to the network with no additional configuration?",
    opts:[
      "The PC does not require any additional information to function on the network.",
      "The PC came preconfigured with IP addressing information from the factory.",
      "The PC was preconfigured to use DHCP.",
      "The PC used DNS to automatically receive IP addressing information from a server.",
      "The PC virtual interface is compatible with any network."
    ],
    ans:[2]
  },
  {
    n:12, multi:false,
    t:"What is a user trying to determine when issuing a ping 10.1.1.1 command on a PC?",
    opts:[
      "If the TCP/IP stack is functioning on the PC without putting traffic on the wire",
      "If there is connectivity with the destination device",
      "The path that traffic will take to reach the destination",
      "What type of device is at the destination"
    ],
    ans:[1]
  },
  {
    n:13, multi:true,
    t:"Which two characters are allowed as part of the hostname of a Cisco device? (Choose two.)",
    opts:["Numbers","Question mark","Space","Tab","Dash"],
    ans:[0,4]
  },
  {
    n:14, multi:false,
    t:"What benefit does DHCP provide to a network?",
    opts:[
      "Hosts always have the same IP address and are therefore always reachable.",
      "DHCP allows users to refer to locations by a name rather than an IP address.",
      "Hosts can connect to the network and get an IP address without manual configuration.",
      "Duplicate addresses cannot occur on a network that issues dynamic addresses using DHCP and has static assignments."
    ],
    ans:[2]
  },
  {
    n:15, multi:false,
    t:"A client packet is received by a server. The packet has a destination port number of 80. What service is the client requesting?",
    opts:["DHCP","SMTP","DNS","HTTP"],
    ans:[3]
  },
  {
    n:16, multi:false,
    t:"What method can be used by two computers to ensure that packets are not dropped because too much data is being sent too quickly?",
    opts:["Encapsulation","Flow control","Access method","Response timeout"],
    ans:[1]
  },
  {
    n:17, multi:false,
    t:"What type of communication will send a message to all devices on a local area network?",
    opts:["Broadcast","Multicast","Unicast","Allcast"],
    ans:[0]
  },
  {
    n:18, multi:false,
    t:"What process is used to place one message inside another message for transfer from the source to the destination?",
    opts:["Access control","Decoding","Encapsulation","Flow control"],
    ans:[2]
  },
  {
    n:19, multi:false,
    t:"A web client is sending a request for a webpage to a web server. From the perspective of the client, what is the correct order of the protocol stack that is used to prepare the request for transmission?",
    opts:[
      "HTTP, IP, TCP, Ethernet",
      "HTTP, TCP, IP, Ethernet",
      "Ethernet, TCP, IP, HTTP",
      "Ethernet, IP, TCP, HTTP"
    ],
    ans:[1]
  },
  {
    n:20, multi:false,
    t:"Which statement is correct about network protocols?",
    opts:[
      "Network protocols define the type of hardware that is used and how it is mounted in racks.",
      "They define how messages are exchanged between the source and the destination.",
      "They all function in the network access layer of TCP/IP.",
      "They are only required for exchange of messages between devices on remote networks."
    ],
    ans:[1]
  },
  {
    n:21, multi:true,
    t:"What three application layer protocols are part of the TCP/IP protocol suite? (Choose three.)",
    opts:["ARP","DHCP","DNS","FTP","NAT","PPP"],
    ans:[1,2,3]
  },
  {
    n:22, multi:true,
    t:"Which three layers of the OSI model are comparable in function to the application layer of the TCP/IP model? (Choose three.)",
    opts:["Application","Presentation","Session","Transport","Data Link","Physical","Network"],
    ans:[0,1,2]
  },
  {
    n:23, multi:false,
    t:"At which layer of the OSI model would a logical address be encapsulated?",
    opts:["Physical layer","Data link layer","Network layer","Transport layer"],
    ans:[2]
  },
  {
    n:24, multi:false,
    t:"What will happen if the default gateway address is incorrectly configured on a host?",
    opts:[
      "The host cannot communicate with other hosts in the local network.",
      "The switch will not forward packets initiated by the host.",
      "The host will have to use ARP to determine the correct address of the default gateway.",
      "The host cannot communicate with hosts in other networks.",
      "A ping from the host to 127.0.0.1 would not be successful."
    ],
    ans:[3]
  },
  {
    n:25, multi:false,
    t:"A computer in a given network is communicating with a specific group of computers. What type of communication is this?",
    opts:["Broadcast","Multicast","Unicast","ARP","HTTP"],
    ans:[1]
  }
];

const LABELS = ['A','B','C','D','E','F','G'];
let userAnswers = {};
let submitted = false;

function buildQuiz() {
  const list = document.getElementById('questions-list');
  list.innerHTML = Q.map(q => `
    <div class="q-card" id="qcard-${q.n}">
      <div class="q-header">
        <span class="q-num">Q${String(q.n).padStart(2,'0')}</span>
        ${q.multi ? `<span class="multi-badge">⚠ Choose ${q.ans.length}</span>` : ''}
      </div>
      <div class="q-text">${q.t}</div>
      <div class="options">
        ${q.opts.map((o,i) => `
          <div class="option" id="opt-${q.n}-${i}" onclick="pick(${q.n},${i},${q.multi})">
            <div class="opt-marker">${LABELS[i]}</div>
            <span>${o}</span>
          </div>`).join('')}
      </div>
    </div>`).join('');
}

function pick(qn, idx, multi) {
  if (submitted) return;
  if (!userAnswers[qn]) userAnswers[qn] = [];
  if (multi) {
    const p = userAnswers[qn].indexOf(idx);
    if (p >= 0) userAnswers[qn].splice(p, 1);
    else userAnswers[qn].push(idx);
  } else {
    userAnswers[qn] = [idx];
  }
  refreshCard(qn);
  updateProgress();
}

function refreshCard(qn) {
  const q = Q.find(x => x.n === qn);
  const sel = userAnswers[qn] || [];
  const card = document.getElementById('qcard-' + qn);
  card.classList.toggle('answered', sel.length > 0);
  q.opts.forEach((_, i) => {
    const el = document.getElementById(`opt-${qn}-${i}`);
    el.className = 'option' + (sel.includes(i) ? ' selected' : '');
  });
}

function updateProgress() {
  const answered = Q.filter(q => (userAnswers[q.n]||[]).length > 0).length;
  const pct = Math.round(answered / Q.length * 100);
  document.getElementById('prog-text').textContent = `${answered} / ${Q.length} answered`;
  document.getElementById('prog-pct').textContent = `${pct}%`;
  document.getElementById('prog-fill').style.width = pct + '%';
  const btn = document.getElementById('submit-btn');
  btn.disabled = answered < Q.length;
  document.getElementById('submit-info').textContent =
    answered < Q.length
      ? `${Q.length - answered} question${Q.length - answered > 1 ? 's' : ''} remaining`
      : 'All answered — ready to submit!';
}

function submitQuiz() {
  submitted = true;
  document.getElementById('quiz-screen').style.display = 'none';
  document.getElementById('result-screen').style.display = 'block';

  let correct = 0;
  Q.forEach(q => {
    const ua = (userAnswers[q.n] || []).slice().sort().join(',');
    const ca = q.ans.slice().sort().join(',');
    if (ua === ca) correct++;
  });
  const wrong = Q.length - correct;
  const pct = Math.round(correct / Q.length * 100);
  const circ = 2 * Math.PI * 52;

  document.getElementById('r-correct').textContent = correct;
  document.getElementById('r-wrong').textContent = wrong;
  document.getElementById('score-pct-text').textContent = pct + '%';

  setTimeout(() => {
    const arc = document.getElementById('score-arc');
    arc.setAttribute('stroke-dasharray', `${circ * pct / 100} ${circ}`);
    if      (pct >= 90) arc.style.stroke = 'var(--green)';
    else if (pct >= 60) arc.style.stroke = 'var(--accent)';
    else                arc.style.stroke = 'var(--red)';
  }, 100);

  const badge = document.getElementById('grade-badge');
  if      (pct >= 90) { badge.textContent = '🏆 Excellent!';   badge.style.cssText = 'background:var(--green-dim);color:var(--green);border:1px solid rgba(104,211,145,0.3)'; }
  else if (pct >= 75) { badge.textContent = '⭐ Very Good';    badge.style.cssText = 'background:var(--accent-dim);color:var(--accent);border:1px solid rgba(45,212,191,0.3)'; }
  else if (pct >= 60) { badge.textContent = '👍 Good';         badge.style.cssText = 'background:var(--amber-dim);color:var(--amber);border:1px solid rgba(246,173,85,0.3)'; }
  else                { badge.textContent = '📚 Needs Review'; badge.style.cssText = 'background:var(--red-dim);color:var(--red);border:1px solid rgba(252,129,129,0.3)'; }

  buildReview();
  window.scrollTo(0, 0);
}

function buildReview() {
  const list = document.getElementById('review-list');
  list.innerHTML = Q.map(q => {
    const ua = (userAnswers[q.n] || []).slice().sort().join(',');
    const ca = q.ans.slice().sort().join(',');
    const isOk = ua === ca;
    const sel = userAnswers[q.n] || [];

    let answersHtml = '';
    if (!isOk && sel.length > 0) {
      answersHtml += `<div class="ri-answer your"><span>✗ Your answer: ${sel.map(i => q.opts[i]).join(' &nbsp;·&nbsp; ')}</span></div>`;
    }
    answersHtml += `<div class="ri-answer correct"><span>✓ Correct: ${q.ans.map(i => q.opts[i]).join(' &nbsp;·&nbsp; ')}</span></div>`;

    return `<div class="review-item ${isOk ? 'ri-correct' : 'ri-wrong'}">
      <div class="ri-header">
        <span class="pill pill-num">Q${String(q.n).padStart(2,'0')}</span>
        <span class="pill ${isOk ? 'pill-green' : 'pill-red'}">${isOk ? '✓ Correct' : '✗ Wrong'}</span>
      </div>
      <div class="ri-q">${q.t}</div>
      <div class="ri-answers">${answersHtml}</div>
    </div>`;
  }).join('');
}

function resetQuiz() {
  userAnswers = {};
  submitted = false;
  document.getElementById('result-screen').style.display = 'none';
  document.getElementById('quiz-screen').style.display = 'block';
  buildQuiz();
  updateProgress();
  window.scrollTo(0, 0);
}

buildQuiz();
updateProgress();
</script>
</body>
</html>
