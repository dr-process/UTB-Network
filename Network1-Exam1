<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Data Communication & Networking — Quiz</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0f1e;
    --surface: #111827;
    --surface2: #1a2235;
    --border: rgba(255,255,255,0.07);
    --border-hover: rgba(99,179,237,0.4);
    --accent: #63b3ed;
    --accent-dim: rgba(99,179,237,0.12);
    --accent-glow: rgba(99,179,237,0.25);
    --green: #68d391;
    --green-dim: rgba(104,211,145,0.12);
    --red: #fc8181;
    --red-dim: rgba(252,129,129,0.12);
    --amber: #f6ad55;
    --amber-dim: rgba(246,173,85,0.12);
    --text: #e2e8f0;
    --muted: #718096;
    --muted2: #4a5568;
    --mono: 'JetBrains Mono', monospace;
    --sans: 'Space Grotesk', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    line-height: 1.6;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(99,179,237,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99,179,237,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .wrap { max-width: 800px; margin: 0 auto; padding: 2rem 1.25rem 5rem; position: relative; z-index: 1; }

  /* Header */
  .hero {
    text-align: center;
    padding: 3rem 2rem 2.5rem;
    background: linear-gradient(135deg, rgba(99,179,237,0.08) 0%, rgba(17,24,39,0) 60%);
    border: 1px solid var(--border);
    border-radius: 20px;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -60px; left: 50%;
    transform: translateX(-50%);
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(99,179,237,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-tag {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 2px;
    text-transform: uppercase;
    background: var(--accent-dim);
    border: 1px solid rgba(99,179,237,0.2);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 1rem;
  }
  .hero h1 {
    font-size: clamp(22px, 4vw, 30px);
    font-weight: 700;
    color: #fff;
    margin-bottom: 6px;
    letter-spacing: -0.5px;
  }
  .hero p { font-size: 15px; color: var(--muted); }

  /* Progress */
  .progress-wrap { margin-bottom: 2rem; }
  .progress-meta {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--muted);
    font-family: var(--mono);
    margin-bottom: 8px;
  }
  .progress-track {
    height: 4px;
    background: var(--surface2);
    border-radius: 4px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), #90cdf4);
    border-radius: 4px;
    transition: width 0.4s cubic-bezier(.4,0,.2,1);
    box-shadow: 0 0 12px rgba(99,179,237,0.4);
  }

  /* Question Card */
  .q-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.75rem;
    margin-bottom: 1rem;
    transition: border-color 0.2s;
  }
  .q-card:hover { border-color: rgba(255,255,255,0.1); }
  .q-card.answered { border-color: rgba(99,179,237,0.2); }

  .q-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1rem;
  }
  .q-num {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-dim);
    border: 1px solid rgba(99,179,237,0.2);
    padding: 3px 10px;
    border-radius: 20px;
    white-space: nowrap;
  }
  .multi-badge {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--amber);
    background: var(--amber-dim);
    border: 1px solid rgba(246,173,85,0.2);
    padding: 3px 10px;
    border-radius: 20px;
  }
  .q-text {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  /* Options */
  .options { display: flex; flex-direction: column; gap: 8px; }
  .option {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 16px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.15s ease;
    font-size: 14px;
    color: var(--text);
    user-select: none;
  }
  .option:hover { border-color: var(--border-hover); background: rgba(99,179,237,0.05); color: #fff; }
  .option.selected { border-color: var(--accent); background: var(--accent-dim); color: #fff; }
  .option.correct { border-color: var(--green); background: var(--green-dim); color: var(--green); }
  .option.wrong { border-color: var(--red); background: var(--red-dim); color: var(--red); }
  .option.show-correct { border-color: var(--green); background: var(--green-dim); color: var(--green); }
  .option.disabled { cursor: default; }

  .opt-marker {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1.5px solid currentColor;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    flex-shrink: 0;
    opacity: 0.7;
  }
  .option.selected .opt-marker,
  .option.correct .opt-marker,
  .option.wrong .opt-marker,
  .option.show-correct .opt-marker { opacity: 1; }

  /* Submit Bar */
  .submit-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    margin-top: 1.5rem;
  }
  .submit-info { font-size: 13px; color: var(--muted); font-family: var(--mono); }

  .btn {
    font-family: var(--sans);
    font-size: 14px;
    font-weight: 600;
    padding: 10px 28px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    transition: all 0.15s ease;
    letter-spacing: 0.3px;
  }
  .btn-primary {
    background: var(--accent);
    color: #0a0f1e;
  }
  .btn-primary:hover { background: #90cdf4; transform: translateY(-1px); box-shadow: 0 4px 20px rgba(99,179,237,0.3); }
  .btn-primary:disabled { opacity: 0.35; cursor: not-allowed; transform: none; box-shadow: none; }
  .btn-ghost {
    background: transparent;
    color: var(--accent);
    border: 1px solid rgba(99,179,237,0.3);
  }
  .btn-ghost:hover { background: var(--accent-dim); }

  /* Result Screen */
  #result-screen { display: none; }

  .result-hero {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2.5rem 2rem;
    text-align: center;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .result-hero::before {
    content: '';
    position: absolute;
    top: -80px; left: 50%;
    transform: translateX(-50%);
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(99,179,237,0.06) 0%, transparent 65%);
    pointer-events: none;
  }

  .score-circle {
    width: 140px;
    height: 140px;
    margin: 0 auto 1.5rem;
    position: relative;
  }
  .score-circle svg { width: 100%; height: 100%; transform: rotate(-90deg); }
  .score-circle-text {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .score-pct { font-size: 30px; font-weight: 700; color: #fff; font-family: var(--mono); }
  .score-lbl { font-size: 11px; color: var(--muted); font-family: var(--mono); letter-spacing: 1px; }

  .grade-badge {
    display: inline-block;
    font-size: 15px;
    font-weight: 600;
    padding: 6px 20px;
    border-radius: 20px;
    margin-bottom: 1rem;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
    margin-top: 1.5rem;
  }
  .stat-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem;
    text-align: center;
  }
  .stat-num { font-size: 28px; font-weight: 700; font-family: var(--mono); }
  .stat-lbl { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .c-green { color: var(--green); }
  .c-red { color: var(--red); }
  .c-blue { color: var(--accent); }

  /* Review */
  .review-heading {
    font-size: 13px;
    font-family: var(--mono);
    color: var(--muted);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 2rem 0 1rem;
    padding-bottom: .75rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .review-heading::before { content: ''; display: block; width: 3px; height: 14px; background: var(--accent); border-radius: 2px; }

  .review-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    margin-bottom: .75rem;
  }
  .review-item.ri-correct { border-color: rgba(104,211,145,0.25); }
  .review-item.ri-wrong { border-color: rgba(252,129,129,0.25); }

  .ri-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: .75rem;
  }
  .ri-q { font-size: 14px; font-weight: 500; color: var(--text); line-height: 1.55; margin-bottom: .75rem; }
  .ri-answers { display: flex; flex-direction: column; gap: 6px; }
  .ri-answer {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    padding: 6px 12px;
    border-radius: 8px;
  }
  .ri-answer.your { background: var(--red-dim); color: var(--red); }
  .ri-answer.correct { background: var(--green-dim); color: var(--green); }
  .ri-answer.your-correct { background: var(--green-dim); color: var(--green); }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 20px;
  }
  .pill-green { background: var(--green-dim); color: var(--green); border: 1px solid rgba(104,211,145,0.25); }
  .pill-red { background: var(--red-dim); color: var(--red); border: 1px solid rgba(252,129,129,0.25); }
  .pill-num { background: var(--surface2); color: var(--muted); border: 1px solid var(--border); }

  .divider { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }

  @media (max-width: 520px) {
    .stats-row { grid-template-columns: 1fr 1fr; }
    .hero { padding: 2rem 1.25rem; }
  }
</style>
</head>
<body>
<div class="wrap">

  <!-- HERO -->
  <div class="hero">
    <div class="hero-tag">Quiz — Chapter Review</div>
    <h1>Data Communication & Networking</h1>
    <p>25 Questions &nbsp;·&nbsp; Multiple Choice &nbsp;·&nbsp; Instant Feedback</p>
  </div>

  <!-- QUIZ SCREEN -->
  <div id="quiz-screen">
    <div class="progress-wrap">
      <div class="progress-meta">
        <span id="prog-text">0 / 25 answered</span>
        <span id="prog-pct">0%</span>
      </div>
      <div class="progress-track"><div class="progress-fill" id="prog-fill" style="width:0%"></div></div>
    </div>

    <div id="questions-list"></div>

    <div class="submit-bar">
      <span class="submit-info" id="submit-info">Answer all questions to submit</span>
      <button class="btn btn-primary" id="submit-btn" disabled onclick="submitQuiz()">Submit Quiz →</button>
    </div>
  </div>

  <!-- RESULT SCREEN -->
  <div id="result-screen">
    <div class="result-hero">
      <div class="score-circle">
        <svg viewBox="0 0 120 120">
          <circle cx="60" cy="60" r="52" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="10"/>
          <circle cx="60" cy="60" r="52" fill="none" stroke="var(--accent)" stroke-width="10"
            stroke-linecap="round" stroke-dasharray="0 327" id="score-arc"
            style="transition: stroke-dasharray 1s cubic-bezier(.4,0,.2,1)"/>
        </svg>
        <div class="score-circle-text">
          <div class="score-pct" id="score-pct-text">0%</div>
          <div class="score-lbl">SCORE</div>
        </div>
      </div>

      <div class="grade-badge" id="grade-badge"></div>

      <div class="stats-row">
        <div class="stat-card"><div class="stat-num c-green" id="r-correct">0</div><div class="stat-lbl">Correct</div></div>
        <div class="stat-card"><div class="stat-num c-red" id="r-wrong">0</div><div class="stat-lbl">Wrong</div></div>
        <div class="stat-card"><div class="stat-num c-blue">25</div><div class="stat-lbl">Total</div></div>
      </div>
    </div>

    <div class="review-heading">Answer Review</div>
    <div id="review-list"></div>

    <hr class="divider">
    <div style="text-align:center">
      <button class="btn btn-ghost" onclick="resetQuiz()">↩ Retake Quiz</button>
    </div>
  </div>

</div>

<script>
const Q = [
  {n:1, t:"Convert the decimal number 231 into its binary equivalent.", opts:["11110010","11011011","11110110","11100111","11100101","11101110"], ans:[3], multi:false},
  {n:2, t:"Which command can be used to test connectivity between two computers that are attached to a network?", opts:["ipconfig","ping","winipcfg","ifconfig","nbtstat -s"], ans:[1], multi:false},
  {n:3, t:"Which type of connector does a network interface card use?", opts:["DIN","PS-2","RJ-11","RJ-45"], ans:[3], multi:false},
  {n:4, t:"A user is having problems accessing the Internet. The command ping www.cisco.com fails. However, pinging the IP address of cisco.com with the command ping 198.133.219.25 is successful. What is the problem?", opts:["The web server is down.","The default gateway is incorrect.","There is a problem with DNS.","The address of the ARP cache is incorrect."], ans:[2], multi:false},
  {n:5, t:"What is the purpose of the routing process?", opts:["To encapsulate data that is used to communicate across a network","To select the paths that are used to direct traffic to destination networks","To convert a URL name into an IP address","To provide secure Internet file transfer","To forward traffic on the basis of MAC addresses"], ans:[1], multi:false},
  {n:6, t:"Which device should be used for enabling a host to communicate with another host on a different network?", opts:["Switch","Hub","Router","Host"], ans:[2], multi:false},
  {n:7, t:"A company is expanding its business to other countries. All branch offices must remain connected to corporate headquarters at all times. Which network technology is required to support this requirement?", opts:["LAN","MAN","WAN","WLAN"], ans:[2], multi:false},
  {n:8, t:"Why would a network administrator use the tracert utility?", opts:["To determine the active TCP connections on a PC","To check information about a DNS name in the DNS server","To identify where a packet was lost or delayed on a network","To display the IP address, default gateway, and DNS server address for a PC"], ans:[2], multi:false},
  {n:9, t:"Which basic process is used to select the best path for forwarding data?", opts:["Routing","Switching","Addressing","Encapsulation"], ans:[0], multi:false},
  {n:10, t:"Which technology provides a solution to IPv4 address depletion by allowing multiple devices to share one public IP address?", opts:["ARP","DNS","NAT","SMB","DHCP","HTTP"], ans:[2], multi:false},
  {n:11, t:"Which subnet would include the address 192.168.1.96 as a usable host address?", opts:["192.168.1.64/26","192.168.1.32/27","192.168.1.32/28","192.168.1.64/29"], ans:[0], multi:false},
  {n:12, t:"What is the purpose of ICMP messages?", opts:["To inform routers about network topology changes","To ensure the delivery of an IP packet","To provide feedback of IP packet transmissions","To monitor the process of a domain name to IP address resolution"], ans:[2], multi:false},
  {n:13, t:"What statement describes the function of the Address Resolution Protocol?", opts:["ARP is used to discover the IP address of any host on a different network.","ARP is used to discover the IP address of any host on the local network.","ARP is used to discover the MAC address of any host on a different network.","ARP is used to discover the MAC address of any host on the local network."], ans:[3], multi:false},
  {n:14, t:"Which three IP addresses are private? (Choose three)", opts:["10.1.1.1","172.32.5.2","192.167.10.10","172.16.4.4","192.168.5.5","224.6.6.6"], ans:[0,3,4], multi:true},
  {n:15, t:"How does a networked server manage requests from multiple clients for different services?", opts:["The server sends all requests through a default gateway.","Each request is assigned source and destination port numbers.","The server uses IP addresses to identify different services.","Each request is tracked through the physical address of the client."], ans:[1], multi:false},
  {n:16, t:"Which protocol translates a website name such as www.cisco.com into a network address?", opts:["HTTP","FTP","DHCP","DNS"], ans:[3], multi:false},
  {n:17, t:"What is an advantage of using IPv6?", opts:["More addresses for networks and hosts","Faster connectivity","Higher bandwidth","More frequencies"], ans:[0], multi:false},
  {n:18, t:"A network technician is attempting to configure an interface by entering the following command: UTB(config)# ip address 192.168.2.1 255.255.255.0. The command is rejected by the device. What is the reason for this?", opts:["The command is being entered from the wrong mode of operation.","The command syntax is wrong.","The subnet mask information is incorrect.","The interface is shutdown and must be enabled before the switch will accept the IP address."], ans:[0], multi:false},
  {n:19, t:"A network administrator is troubleshooting connectivity issues on a server. Using a tester, the administrator notices that the signals generated by the server NIC are distorted and not usable. In which layer of the OSI model is the error categorized?", opts:["Presentation Layer","Network Layer","Physical Layer","Data Link Layer"], ans:[2], multi:false},
  {n:20, t:"A wireless host needs to request an IP address. What protocol would be used to process the request?", opts:["FTP","HTTP","DHCP","ICMP","SNMP"], ans:[2], multi:false},
  {n:21, t:"Which connection provides a secure CLI session with encryption to a Cisco switch?", opts:["A console connection","An AUX connection","A Telnet connection","An SSH connection"], ans:[3], multi:false},
  {n:22, t:"Which device performs the function of determining the path that messages should take through internetworks?", opts:["A router","A firewall","A web server","A DSL modem"], ans:[0], multi:false},
  {n:23, t:"Which area of the network would a college IT staff most likely have to redesign as a direct result of many students bringing their own tablets and smartphones to school to access school resources?", opts:["Extranet","Intranet","Wired LAN","Wireless LAN","Wireless WAN"], ans:[3], multi:false},
  {n:24, t:"What is the Internet?", opts:["It is a network based on Ethernet technology.","It provides network access for mobile devices.","It provides connections through interconnected global networks.","It is a private network for an organization with LAN and WAN connections."], ans:[2], multi:false},
  {n:25, t:"What type of network must a home user access in order to do online shopping?", opts:["An intranet","The Internet","An extranet","A local area network"], ans:[1], multi:false}
];

const LABELS = ['A','B','C','D','E','F'];
let userAnswers = {};
let submitted = false;

function buildQuiz() {
  const list = document.getElementById('questions-list');
  list.innerHTML = Q.map(q => `
    <div class="q-card" id="qcard-${q.n}">
      <div class="q-header">
        <span class="q-num">Q${String(q.n).padStart(2,'0')}</span>
        ${q.multi ? '<span class="multi-badge">⚠ Choose 3</span>' : ''}
      </div>
      <div class="q-text">${q.t}</div>
      <div class="options">
        ${q.opts.map((o,i) => `
          <div class="option" id="opt-${q.n}-${i}" onclick="pick(${q.n},${i},${q.multi})">
            <div class="opt-marker">${LABELS[i]}</div>
            <span>${o}</span>
          </div>`).join('')}
      </div>
    </div>`).join('');
}

function pick(qn, idx, multi) {
  if (submitted) return;
  if (!userAnswers[qn]) userAnswers[qn] = [];
  if (multi) {
    const p = userAnswers[qn].indexOf(idx);
    if (p >= 0) userAnswers[qn].splice(p, 1);
    else userAnswers[qn].push(idx);
  } else {
    userAnswers[qn] = [idx];
  }
  refreshCard(qn);
  updateProgress();
}

function refreshCard(qn) {
  const q = Q.find(x => x.n === qn);
  const sel = userAnswers[qn] || [];
  const card = document.getElementById('qcard-' + qn);
  card.classList.toggle('answered', sel.length > 0);
  q.opts.forEach((_, i) => {
    const el = document.getElementById(`opt-${qn}-${i}`);
    el.className = 'option' + (sel.includes(i) ? ' selected' : '');
  });
}

function updateProgress() {
  const answered = Q.filter(q => (userAnswers[q.n]||[]).length > 0).length;
  const pct = Math.round(answered / Q.length * 100);
  document.getElementById('prog-text').textContent = `${answered} / ${Q.length} answered`;
  document.getElementById('prog-pct').textContent = `${pct}%`;
  document.getElementById('prog-fill').style.width = pct + '%';
  const btn = document.getElementById('submit-btn');
  btn.disabled = answered < Q.length;
  document.getElementById('submit-info').textContent =
    answered < Q.length ? `${Q.length - answered} question${Q.length - answered > 1 ? 's' : ''} remaining` : 'All answered — ready to submit!';
}

function submitQuiz() {
  submitted = true;
  document.getElementById('quiz-screen').style.display = 'none';
  document.getElementById('result-screen').style.display = 'block';

  let correct = 0;
  Q.forEach(q => {
    const ua = (userAnswers[q.n] || []).slice().sort().join(',');
    const ca = q.ans.slice().sort().join(',');
    if (ua === ca) correct++;
  });
  const wrong = Q.length - correct;
  const pct = Math.round(correct / Q.length * 100);
  const circ = 2 * Math.PI * 52;

  document.getElementById('r-correct').textContent = correct;
  document.getElementById('r-wrong').textContent = wrong;
  document.getElementById('score-pct-text').textContent = pct + '%';
  setTimeout(() => {
    document.getElementById('score-arc').setAttribute('stroke-dasharray', `${circ * pct / 100} ${circ}`);
    const arc = document.getElementById('score-arc');
    if (pct >= 90) arc.style.stroke = 'var(--green)';
    else if (pct >= 60) arc.style.stroke = 'var(--accent)';
    else arc.style.stroke = 'var(--red)';
  }, 100);

  const badge = document.getElementById('grade-badge');
  if (pct >= 90) { badge.textContent = '🏆 Excellent!'; badge.style.cssText = 'background:var(--green-dim);color:var(--green);border:1px solid rgba(104,211,145,0.3)'; }
  else if (pct >= 75) { badge.textContent = '⭐ Very Good'; badge.style.cssText = 'background:var(--accent-dim);color:var(--accent);border:1px solid rgba(99,179,237,0.3)'; }
  else if (pct >= 60) { badge.textContent = '👍 Good'; badge.style.cssText = 'background:var(--amber-dim);color:var(--amber);border:1px solid rgba(246,173,85,0.3)'; }
  else { badge.textContent = '📚 Needs Review'; badge.style.cssText = 'background:var(--red-dim);color:var(--red);border:1px solid rgba(252,129,129,0.3)'; }

  buildReview();
  window.scrollTo(0, 0);
}

function buildReview() {
  const list = document.getElementById('review-list');
  list.innerHTML = Q.map(q => {
    const ua = (userAnswers[q.n] || []).slice().sort().join(',');
    const ca = q.ans.slice().sort().join(',');
    const isOk = ua === ca;
    const sel = userAnswers[q.n] || [];

    let answersHtml = '';
    if (!isOk && sel.length > 0) {
      answersHtml += `<div class="ri-answer your"><span>✗ Your answer: ${sel.map(i => q.opts[i]).join(', ')}</span></div>`;
    }
    answersHtml += `<div class="ri-answer correct"><span>✓ Correct: ${q.ans.map(i => q.opts[i]).join(', ')}</span></div>`;

    return `<div class="review-item ${isOk ? 'ri-correct' : 'ri-wrong'}">
      <div class="ri-header">
        <span class="pill pill-num">Q${String(q.n).padStart(2,'0')}</span>
        <span class="pill ${isOk ? 'pill-green' : 'pill-red'}">${isOk ? '✓ Correct' : '✗ Wrong'}</span>
      </div>
      <div class="ri-q">${q.t}</div>
      <div class="ri-answers">${answersHtml}</div>
    </div>`;
  }).join('');
}

function resetQuiz() {
  userAnswers = {};
  submitted = false;
  document.getElementById('result-screen').style.display = 'none';
  document.getElementById('quiz-screen').style.display = 'block';
  buildQuiz();
  updateProgress();
  window.scrollTo(0, 0);
}

buildQuiz();
updateProgress();
</script>
</body>
</html>
